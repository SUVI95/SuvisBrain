# Neon database connection string
# Get this from: https://console.neon.tech → your project → Connection Details
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# OpenAI API key — for Knuut voice (real-time only)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# OpenRouter keys — for non-realtime tasks (summaries, analysis, etc.) to save OpenAI usage
# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_API_KEY_2=sk-or-v1-...

# JWT auth — set a strong secret in production
JWT_SECRET=your-secret-change-in-production

# CORS — comma-separated origins (optional; default includes localhost + suvisbrain.vercel.app)
# ALLOWED_ORIGINS=https://yourapp.com,https://www.yourapp.com

# Resend — weekly emails (get from resend.com)
RESEND_API_KEY=re_...
RESEND_FROM=Knuut <onboarding@resend.dev>

# Cron — secret to protect /api/cron-weekly (Vercel sets this for cron)
CRON_SECRET=optional-cron-secret
