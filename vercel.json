{
  "version": 2,
  "builds": [
    { "src": "api/index.js", "use": "@vercel/node" },
    { "src": "api/session.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/session", "dest": "/api/session" },
    { "src": "/api/(.*)", "dest": "/api?path=$1" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ],
  "crons": [
    { "path": "/api/cron-weekly", "schedule": "0 9 * * 1" }
  ]
}
